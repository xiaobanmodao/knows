<view class="page-shell" wx:if="{{knowledge}}">
  <view wx:if="{{context}}" class="context-path" bindtap="openContext">{{subjectLabel}} / {{context.title}} / 知识点</view>

  <view class="knowledge-hero card">
    <view class="knowledge-hero__meta">
      <view class="pill">{{subjectLabel}} · {{context.title}}</view>
      <view class="collect-btn {{isFavorite ? 'collect-btn--active' : ''}}" bindtap="toggleFavorite">
        {{isFavorite ? '已收藏' : '收藏'}}
      </view>
    </view>
    <view class="knowledge-hero__title">{{knowledge.title}}</view>
    <view class="knowledge-hero__summary">{{knowledge.summary}}</view>
    <view class="knowledge-hero__tags">
      <text wx:for="{{knowledge.tags}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
    <view wx:if="{{knowledge.contentMeta}}" class="content-review">
      {{knowledge.contentMeta.statusLabel}} · {{knowledge.contentMeta.reviewedAt}} · {{knowledge.contentMeta.sourceLabel}}
    </view>
  </view>

  <view wx:if="{{knowledge.knowledgePoints && knowledge.knowledgePoints.length}}" class="core-card card top-gap">
    <view class="core-card__head">
      <view>
        <view class="core-card__title">核心概念</view>
        <view class="core-card__meta">{{knowledge.knowledgePoints.length}} 条必须掌握的结论</view>
      </view>
      <view class="text-command" bindtap="copyCoreContent">复制</view>
    </view>
    <view wx:for="{{knowledge.knowledgePoints}}" wx:key="index" class="core-card__item">
      <view class="core-card__index">{{index + 1}}</view>
      <view class="core-card__text">{{item}}</view>
    </view>
  </view>

  <view wx:if="{{knowledge.coverImage}}" class="knowledge-figure card top-gap">
    <view class="knowledge-figure__title">关键图解</view>
    <image wx:if="{{!coverImageLoadFailed}}" class="knowledge-figure__image" src="{{knowledge.coverImage}}" mode="aspectFit" binderror="onCoverImageError"></image>
    <view wx:else class="knowledge-figure__fallback">图示暂未加载，文字内容可继续阅读</view>
    <view class="knowledge-figure__caption">{{knowledge.figureCaption}}</view>
  </view>

  <view wx:if="{{essentialSections.length}}" class="section-title top-gap">
    <view class="section-title__main">公式与结构</view>
    <view class="section-title__sub">{{essentialSections.length}} 个重点模块</view>
  </view>
  <view wx:if="{{essentialSections.length}}">
    <content-block wx:for="{{essentialSections}}" wx:key="title" section="{{item}}" />
  </view>

  <view wx:if="{{detailSections.length}}" class="fold-control card" bindtap="toggleDetails">
    <view>
      <view class="fold-control__title">完整讲解</view>
      <view class="fold-control__meta">{{detailSections.length}} 个补充模块</view>
    </view>
    <view class="fold-control__action">{{detailsExpanded ? '收起' : '展开'}} {{detailsExpanded ? '⌃' : '⌄'}}</view>
  </view>
  <view wx:if="{{detailsExpanded}}" class="top-gap">
    <content-block wx:for="{{detailSections}}" wx:key="title" section="{{item}}" />
  </view>

  <view wx:if="{{knowledge.mistakeChecklist && knowledge.mistakeChecklist.length}}" class="study-card study-card--warn card top-gap">
    <view class="study-card__title">易错辨析</view>
    <view wx:for="{{knowledge.mistakeChecklist}}" wx:key="index" class="study-card__item">
      <view class="study-card__index">!</view>
      <view class="study-card__text">{{item}}</view>
    </view>
  </view>

  <view class="note-card card top-gap">
    <view class="note-card__head">
      <view>
        <view class="note-card__title">我的笔记</view>
        <view class="note-card__meta">仅保存在本机</view>
      </view>
      <view class="note-card__save {{noteDirty ? 'note-card__save--active' : ''}}" bindtap="saveNote">保存</view>
    </view>
    <textarea
      class="note-card__input"
      value="{{noteDraft}}"
      maxlength="800"
      auto-height
      placeholder="记录理解、易错点或补充公式"
      bindinput="onNoteInput"
    ></textarea>
    <view wx:if="{{noteTags.length}}" class="note-card__tags">
      <view wx:for="{{noteTags}}" wx:key="*this" class="note-tag">
        <text>{{item}}</text>
        <text class="note-tag__remove" data-index="{{index}}" bindtap="removeNoteTag">×</text>
      </view>
    </view>
    <view class="note-card__tag-row">
      <input class="note-card__tag-input" value="{{noteTagDraft}}" maxlength="12" placeholder="添加标签" bindinput="onNoteTagInput" bindconfirm="addNoteTag" confirm-type="done" />
      <view class="note-card__tag-add" bindtap="addNoteTag">+</view>
    </view>
  </view>

  <view wx:if="{{knowledge.template}}" class="template-box card top-gap">
    <view class="template-box__head" bindtap="toggleTemplate">
      <view>
        <view class="template-box__title">方法步骤</view>
        <view class="template-box__name">{{knowledge.template.name}}</view>
      </view>
      <view class="fold-control__action">{{templateExpanded ? '收起' : '展开'}} {{templateExpanded ? '⌃' : '⌄'}}</view>
    </view>
    <view class="template-box__when">{{knowledge.template.whenToUse}}</view>
    <view wx:if="{{templateExpanded}}">
      <view wx:for="{{knowledge.template.steps}}" wx:key="index" class="template-box__step">
        <view class="template-box__index">{{index + 1}}</view>
        <view class="template-box__text">{{item}}</view>
      </view>
    </view>
  </view>

  <view class="section-title top-gap">
    <view class="section-title__main">典型例子</view>
    <view class="section-title__sub">{{knowledge.problems.length}} 道原创示例</view>
  </view>

  <view class="problem-list">
    <view wx:for="{{knowledge.problems}}" wx:key="title" wx:for-item="problem" class="problem-card card">
      <view class="problem-card__top">
        <view class="problem-card__title">{{problem.title}}</view>
        <view class="pill">{{problem.difficulty}}</view>
      </view>
      <view class="problem-card__section">
        <text class="problem-card__label">题干：</text>{{problem.stem}}
      </view>
      <view class="problem-card__toggle" data-index="{{index}}" bindtap="toggleProblem">{{problem.expanded ? '收起解析' : '展开解析'}}</view>
      <view wx:if="{{problem.expanded}}">
        <image wx:if="{{problem.image && !problem.imageLoadFailed}}" class="problem-card__image" src="{{problem.image}}" mode="aspectFit" data-index="{{index}}" binderror="onProblemImageError"></image>
        <view wx:elif="{{problem.image && problem.imageLoadFailed}}" class="problem-card__image-fallback">例题图暂未加载，可先阅读题干和解析</view>
        <view wx:if="{{problem.steps && problem.steps.length}}" class="problem-card__steps">
          <view class="problem-card__label">解题过程：</view>
          <view wx:for="{{problem.steps}}" wx:key="index" class="problem-step">
            <view class="problem-step__index">{{index + 1}}</view>
            <view class="problem-step__text">{{item}}</view>
          </view>
        </view>
        <view class="problem-card__section">
          <text class="problem-card__label">答案：</text>{{problem.answer}}
        </view>
        <view class="problem-card__section">
          <text class="problem-card__label">解析：</text>{{problem.analysis}}
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{relatedItems.length}}" class="section-title top-gap">
    <view class="section-title__main">相关知识</view>
    <view class="section-title__sub">{{context.title}}</view>
  </view>
  <view wx:if="{{relatedItems.length}}" class="grid">
    <view wx:for="{{relatedItems}}" wx:key="id" wx:for-item="related" class="related-card card" data-id="{{related.id}}" bindtap="openRelated">
      <view class="related-card__title">{{related.title}}</view>
      <view class="related-card__summary">{{related.summary}}</view>
    </view>
  </view>

  <view wx:if="{{navigation}}" class="page-navigation">
    <view class="page-navigation__item {{navigation.previous ? '' : 'page-navigation__item--disabled'}}" data-id="{{navigation.previous.id}}" bindtap="openAdjacent">
      <view class="page-navigation__direction">‹ 上一知识点</view>
      <view class="page-navigation__title">{{navigation.previous ? navigation.previous.title : '已经是第一个知识点'}}</view>
    </view>
    <view class="page-navigation__item page-navigation__item--next {{navigation.next ? '' : 'page-navigation__item--disabled'}}" data-id="{{navigation.next.id}}" bindtap="openAdjacent">
      <view class="page-navigation__direction">下一知识点 ›</view>
      <view class="page-navigation__title">{{navigation.next ? navigation.next.title : '已经是最后一个知识点'}}</view>
    </view>
  </view>
</view>
