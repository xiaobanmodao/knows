page {
  min-height: 100%;
  background: linear-gradient(180deg, #f7f8fc 0%, #eff3ff 100%);
  color: #1f2a44;
  font-family: "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.legacy-route {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  color: #252a34;
  text-align: center;
}

.legacy-route__indicator {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 28rpx;
  border: 6rpx solid #d8dde8;
  border-top-color: #165dff;
  border-radius: 50%;
  animation: legacy-route-spin 0.8s linear infinite;
}

.legacy-route__title {
  font-size: 34rpx;
  font-weight: 700;
}

.legacy-route__message {
  max-width: 520rpx;
  margin-top: 16rpx;
  color: #707789;
  font-size: 26rpx;
  line-height: 1.6;
}

.legacy-route__retry {
  margin-top: 32rpx;
  padding: 18rpx 40rpx;
  border-radius: 8rpx;
  background: #165dff;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

@keyframes legacy-route-spin {
  to { transform: rotate(360deg); }
}

.page-shell {
  padding: 28rpx 24rpx 40rpx;
}

.card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  box-shadow: 0 14rpx 48rpx rgba(49, 83, 177, 0.09);
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title__main {
  font-size: 34rpx;
  font-weight: 700;
  color: #15213c;
}

.section-title__sub {
  font-size: 24rpx;
  color: #6d7488;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #eef3ff;
  color: #2357d8;
}

.muted {
  color: #7b8295;
}

.grid {
  display: grid;
  gap: 20rpx;
}

.hero-gradient {
  background: linear-gradient(135deg, #165dff 0%, #4589ff 60%, #91b5ff 100%);
  color: #ffffff;
}

.clickable {
  transition: transform 0.2s ease;
}

.tag {
  display: inline-flex;
  align-items: center;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #f0f4ff;
  color: #2357d8;
}

.empty-gap {
  height: 20rpx;
}

.context-path {
  margin-bottom: 18rpx;
  color: #49658f;
  font-size: 22rpx;
  line-height: 1.6;
}

.context-path--physics { color: #9a4a27; }

.page-navigation {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 28rpx;
}

.page-navigation__item {
  min-width: 0;
  min-height: 108rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #dfe6f2;
  border-radius: 16rpx;
  background: #ffffff;
}

.page-navigation__item--next { text-align: right; }
.page-navigation__item--disabled { opacity: 0.5; }
.page-navigation__direction { color: #2357d8; font-size: 21rpx; font-weight: 700; }
.page-navigation__title { margin-top: 7rpx; color: #27334b; font-size: 23rpx; line-height: 1.45; }

.content-review {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(91, 111, 148, 0.16);
  color: #68758b;
  font-size: 20rpx;
  line-height: 1.65;
}

.content-review--light {
  border-top-color: rgba(255, 255, 255, 0.24);
  color: rgba(255, 255, 255, 0.82);
}
