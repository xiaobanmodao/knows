.profile-card {
  padding: 30rpx;
}

.profile-card__label {
  display: inline-flex;
  align-items: center;
  margin-bottom: 14rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.18);
}

.profile-card__title {
  font-size: 40rpx;
  font-weight: 800;
}

.profile-card__desc {
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 1.9;
}

.info-card {
  padding: 30rpx;
}

.info-card__item {
  margin-bottom: 14rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #4f5971;
}

.info-card__item:last-child {
  margin-bottom: 0;
}

.roadmap-card {
  display: flex;
  align-items: center;
  padding: 26rpx;
}

.roadmap-card__index {
  width: 46rpx;
  height: 46rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: #165dff;
  color: #ffffff;
  text-align: center;
  line-height: 46rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.roadmap-card__text {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.8;
  color: #31405f;
}

.beian-card {
  margin-top: 32rpx;
}

.info-card__hint {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #7b8295;
}

.top-gap {
  margin-top: 32rpx;
}
