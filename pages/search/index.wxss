.top-gap {
  margin-top: 26rpx;
}

.search-note {
  margin-top: 16rpx;
  padding: 0 4rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #677086;
}

.quick-panel {
  padding-bottom: 10rpx;
}

.keyword-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.keyword-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #42506b;
  font-size: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(49, 83, 177, 0.08);
}

.keyword-chip--strong {
  background: #eef3ff;
  color: #2357d8;
}

.result-group {
  margin-bottom: 30rpx;
}

.result-group__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.result-group__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #15213c;
}

.result-group__count {
  font-size: 23rpx;
  color: #7b8295;
}

.result-card {
  padding: 28rpx;
}

.result-card__top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.result-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a2643;
}

.result-card__subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #5c6680;
}

.result-card__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #4e5970;
}

.result-card__tags {
  margin-top: 12rpx;
}
