.top-gap {
  margin-top: 26rpx;
}

.search-note {
  margin-top: 16rpx;
  padding: 0 4rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #677086;
}

.result-card {
  padding: 28rpx;
}

.result-card__top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.result-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a2643;
}

.result-card__subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #5c6680;
}

.result-card__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #4e5970;
}

.result-card__tags {
  margin-top: 12rpx;
}
