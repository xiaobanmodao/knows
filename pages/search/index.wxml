<view class="page-shell">
  <search-bar value="{{query}}" autoFocus="{{true}}" bind:change="onChange" bind:submit="onSubmit" />
  <view class="subject-filter">
    <view wx:for="{{subjectFilters}}" wx:key="id" wx:for-item="filter" class="subject-filter__item {{selectedSubjectId === filter.id ? 'subject-filter__item--active' : ''}}" data-id="{{filter.id}}" bindtap="selectSubject">{{filter.title}}</view>
  </view>
  <view class="search-note">搜索教材单元、英语单词与语法，以及三科学科知识和方法。</view>

  <view wx:if="{{!hasSearched}}" class="quick-panel">
    <view wx:if="{{searchHistory.length}}" class="section-title top-gap">
      <view class="section-title__main">最近搜索</view>
      <view class="section-title__sub">{{searchHistory.length}} 条</view>
    </view>
    <view wx:if="{{searchHistory.length}}" class="keyword-row">
      <view
        wx:for="{{searchHistory}}"
        wx:key="*this"
        wx:for-item="keyword"
        class="keyword-chip"
        data-keyword="{{keyword}}"
        bindtap="selectKeyword"
      >{{keyword}}</view>
    </view>

    <view class="section-title top-gap">
      <view class="section-title__main">推荐搜索</view>
      <view class="section-title__sub">高频入口</view>
    </view>
    <view class="keyword-row">
      <view
        wx:for="{{recommendedKeywords}}"
        wx:key="*this"
        wx:for-item="keyword"
        class="keyword-chip keyword-chip--strong"
        data-keyword="{{keyword}}"
        bindtap="selectKeyword"
      >{{keyword}}</view>
    </view>
  </view>

  <view wx:else>
    <view class="section-title top-gap">
      <view class="section-title__main">搜索结果</view>
      <view class="section-title__sub">{{results.length}} 条</view>
    </view>

    <scroll-view wx:if="{{typeFilters.length > 1}}" class="type-filter" scroll-x enable-flex>
      <view
        wx:for="{{typeFilters}}"
        wx:key="id"
        wx:for-item="filter"
        class="type-filter__item {{selectedType === filter.id ? 'type-filter__item--active' : ''}}"
        data-id="{{filter.id}}"
        bindtap="selectType"
      >{{filter.title}} {{filter.count}}</view>
    </scroll-view>

    <view wx:if="{{groupedResults.length}}">
      <view wx:for="{{groupedResults}}" wx:key="key" wx:for-item="group" class="result-group">
        <view class="result-group__header">
          <view class="result-group__title">{{group.title}}</view>
          <view class="result-group__count">{{group.count}} 条</view>
        </view>
        <view class="grid">
          <view
            wx:for="{{group.items}}"
            wx:key="id"
            wx:for-item="result"
            class="result-card card"
            data-type="{{result.type}}"
            data-id="{{result.refId}}"
            data-subject-id="{{result.subjectId}}"
            data-focus-id="{{result.focusId}}"
            bindtap="openResult"
          >
            <view class="result-card__top">
              <view class="result-card__title">{{result.title}}</view>
              <view class="pill">{{result.subjectLabel}} · {{result.typeLabel}}</view>
            </view>
            <view class="result-card__subtitle">{{result.subtitle}}</view>
            <view class="result-card__desc">{{result.description}}</view>
            <view class="result-card__tags">
              <text wx:for="{{result.tags}}" wx:key="*this" wx:for-item="tag" class="tag">{{tag}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    <empty-state wx:else title="没有找到匹配内容" description="换个关键词试试，比如单元名、单词、语法、题型或公式。" />
  </view>
</view>
