.chapter-hero {
  padding: 32rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 214, 102, 0.18), transparent 24%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 255, 0.96) 100%);
  border: 1rpx solid rgba(61, 94, 186, 0.08);
}

.chapter-hero__head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.chapter-hero__badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #17233f;
  color: #ffffff;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.chapter-hero__title {
  margin-top: 18rpx;
  font-size: 46rpx;
  font-weight: 800;
  color: #16213c;
  line-height: 1.2;
}

.chapter-hero__subtitle {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #536079;
}

.chapter-hero__highlight {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #eef4ff 0%, #f8fbff 100%);
  font-size: 24rpx;
  line-height: 1.9;
  color: #40506d;
}

.chapter-figure {
  margin-top: 24rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid #e7edf8;
}

.chapter-figure__image {
  width: 100%;
  height: 360rpx;
  display: block;
}

.chapter-figure__fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 240rpx;
  border-radius: 18rpx;
  background: #f4f7ff;
  border: 1rpx dashed #cbd7ee;
  color: #6c7690;
  font-size: 24rpx;
  line-height: 1.7;
  text-align: center;
}

.chapter-figure__caption {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #647089;
}

.chapter-hero__tags {
  margin-top: 18rpx;
}

.chapter-hero__stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.chapter-hero__stat {
  padding: 18rpx;
  border-radius: 22rpx;
  background: #f4f7ff;
  border: 1rpx solid rgba(80, 108, 185, 0.08);
}

.chapter-hero__stat--strong {
  background: linear-gradient(135deg, #1b5fff 0%, #3e82ff 100%);
}

.chapter-hero__stat--strong .chapter-hero__stat-num,
.chapter-hero__stat--strong .chapter-hero__stat-label {
  color: #ffffff;
}

.chapter-hero__stat-num {
  font-size: 32rpx;
  font-weight: 800;
  color: #1e56da;
}

.chapter-hero__stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #697389;
}

.top-gap {
  margin-top: 28rpx;
}

.topic-guide {
  padding: 28rpx;
  border: 1rpx solid rgba(23, 111, 92, 0.14);
  background: #ffffff;
}

.topic-guide__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.topic-guide__label {
  font-size: 22rpx;
  line-height: 1.4;
  color: #15745f;
  font-weight: 700;
}

.topic-guide__title {
  margin-top: 8rpx;
  font-size: 34rpx;
  line-height: 1.3;
  color: #17233f;
  font-weight: 800;
}

.topic-guide__count {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f7f2;
  color: #15745f;
  font-size: 21rpx;
  line-height: 1.4;
}

.topic-guide__summary {
  margin-top: 14rpx;
  color: #59657a;
  font-size: 24rpx;
  line-height: 1.75;
}

.topic-guide__section-title {
  margin-top: 24rpx;
  color: #1b2742;
  font-size: 27rpx;
  font-weight: 800;
}

.topic-checkpoints {
  margin-top: 8rpx;
}

.topic-checkpoint {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf1f6;
}

.topic-checkpoint:last-child {
  border-bottom: 0;
}

.topic-checkpoint__index {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: #17233f;
  color: #ffffff;
  font-size: 20rpx;
  line-height: 40rpx;
  text-align: center;
  font-weight: 700;
}

.topic-checkpoint__body {
  flex: 1;
  min-width: 0;
}

.topic-checkpoint__title {
  color: #1d2943;
  font-size: 25rpx;
  line-height: 1.5;
  font-weight: 700;
}

.topic-checkpoint__method {
  margin-top: 6rpx;
  color: #5b667c;
  font-size: 23rpx;
  line-height: 1.75;
}

.topic-guide__signals {
  margin-top: 14rpx;
}

.topic-signal {
  display: inline-flex;
  align-items: center;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fff4df;
  color: #8a5c09;
  font-size: 21rpx;
  line-height: 1.35;
}

.chapter-dashboard {
  display: grid;
  gap: 20rpx;
}

.chapter-panel,
.outline-card,
.model-card,
.knowledge-card {
  padding: 28rpx;
}

.chapter-panel {
  background:
    linear-gradient(135deg, rgba(18, 34, 69, 0.98) 0%, rgba(29, 58, 118, 0.95) 100%);
  color: #ffffff;
}

.chapter-panel__title {
  font-size: 30rpx;
  font-weight: 700;
}

.chapter-panel__intro {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.85;
  color: rgba(255, 255, 255, 0.84);
}

.chapter-panel__chips {
  display: grid;
  gap: 16rpx;
  margin-top: 22rpx;
}

.chapter-chip {
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.chapter-chip__label {
  display: block;
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.68);
}

.chapter-chip__value {
  display: block;
  margin-top: 8rpx;
  font-size: 27rpx;
  line-height: 1.6;
  color: #ffffff;
  font-weight: 700;
}

.outline-card {
  border: 1rpx solid rgba(66, 96, 167, 0.08);
}

.outline-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1b2642;
}

.outline-card__item {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
}

.outline-card__index {
  width: 42rpx;
  height: 42rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 42rpx;
  font-size: 21rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.outline-card__index {
  background: #edf3ff;
  color: #1d5de1;
}

.outline-card__text {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.85;
  color: #44506a;
}

.review-card {
  padding: 28rpx;
  border: 1rpx solid rgba(66, 96, 167, 0.08);
  background: #ffffff;
}

.review-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.review-card__title {
  font-size: 30rpx;
  font-weight: 800;
  color: #18233d;
}

.review-card__subtitle {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #66728a;
}

.review-card__badge {
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  background: #eff5ff;
  color: #1e5ee8;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.review-card__grid {
  display: grid;
  gap: 18rpx;
  margin-top: 22rpx;
}

.review-group {
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f8fbff;
  border: 1rpx solid #edf2fb;
}

.review-group__title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a2744;
}

.review-group__subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.65;
  color: #6b7488;
}

.review-group__items {
  margin-top: 14rpx;
}

.review-group__item {
  position: relative;
  padding-left: 20rpx;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.75;
  color: #42506b;
}

.review-group__item:first-child {
  margin-top: 0;
}

.review-group__item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 15rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #1e5ee8;
}

.textbook-card {
  padding: 28rpx;
  border: 1rpx solid rgba(66, 96, 167, 0.08);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(250, 251, 255, 0.96) 100%);
}

.textbook-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #18233d;
}

.textbook-card__item {
  display: flex;
  align-items: flex-start;
  margin-top: 16rpx;
}

.textbook-card__dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 14rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: #2463f0;
  flex-shrink: 0;
}

.textbook-card__dot--solve {
  background: #1e9d61;
}

.textbook-card__dot--warn {
  background: #f39b13;
}

.textbook-card__text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.85;
  color: #49566f;
}

.knowledge-card {
  border: 1rpx solid rgba(66, 96, 167, 0.08);
}

.knowledge-card__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #18233d;
}

.knowledge-card__summary {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.85;
  color: #556178;
}

.knowledge-card__points {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #f8fbff;
  border: 1rpx solid #edf2fb;
}

.knowledge-card__point {
  position: relative;
  padding-left: 18rpx;
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.8;
  color: #47546f;
}

.knowledge-card__point:first-child {
  margin-top: 0;
}

.knowledge-card__point::before {
  content: '';
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #2463f0;
}

.knowledge-card__tags {
  margin-top: 14rpx;
}

.knowledge-card__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx 22rpx;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #7a8397;
}

.knowledge-card__footer {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf1fa;
  font-size: 23rpx;
  color: #2463f0;
  font-weight: 700;
}

.model-card {
  border: 1rpx solid rgba(66, 96, 167, 0.08);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(249, 251, 255, 0.95) 100%);
}

.model-card__top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.model-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #17243f;
}

.model-card__summary {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #5f6980;
}
