.bookmark-card {
  padding: 28rpx;
}

.bookmark-card__title {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #18233e;
}

.bookmark-card__badge { display: inline-flex; padding: 7rpx 12rpx; border-radius: 999rpx; background: #edf3ff; color: #2357d8; font-size: 20rpx; }

.bookmark-card__subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #697286;
  line-height: 1.8;
}

.top-gap {
  margin-top: 32rpx;
}
