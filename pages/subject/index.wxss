.subject-hero {
  padding: 34rpx 30rpx;
  border-radius: 28rpx;
  color: #ffffff;
}

.subject-hero--english { background: linear-gradient(135deg, #087a4b, #31a66e); }
.subject-hero--physics { background: linear-gradient(135deg, #c34e21, #e78b2e); }

.subject-hero__eyebrow { font-size: 22rpx; opacity: 0.85; }
.subject-hero__title { margin-top: 12rpx; font-size: 42rpx; font-weight: 800; }
.subject-hero__desc { margin-top: 14rpx; font-size: 25rpx; line-height: 1.8; opacity: 0.95; }

.subject-hero__stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 26rpx;
}

.subject-stat {
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.14);
  text-align: center;
  font-size: 21rpx;
}

.subject-stat__num { display: block; margin-bottom: 4rpx; font-size: 30rpx; font-weight: 800; }

.subject-search {
  margin-top: 22rpx;
  padding: 22rpx 26rpx;
  border: 1rpx solid #dfe6f2;
  border-radius: 16rpx;
  background: #ffffff;
  color: #677086;
  font-size: 24rpx;
}

.top-gap { margin-top: 30rpx; }
.book-tabs {
  width: 100%;
  margin: 4rpx 0 18rpx;
  white-space: nowrap;
}

.book-tabs__inner { display: flex; gap: 12rpx; padding: 4rpx 2rpx; }

.book-tab {
  display: inline-flex;
  flex: 0 0 auto;
  align-items: center;
  min-width: 92rpx;
  height: 66rpx;
  padding: 0 22rpx;
  border: 1rpx solid #dce6e1;
  border-radius: 12rpx;
  background: #ffffff;
  color: #42564d;
  font-size: 24rpx;
  font-weight: 700;
}

.book-tab--active { border-color: #14845a; background: #e9f7f0; color: #087a4b; }
.physics-book-tab { border-color: #eadfd8; color: #76503c; }
.physics-book-tab--active { border-color: #c85a2d; background: #fff0e9; color: #a63f17; }
.book-tab--disabled { color: #a2a8b1; background: #f2f3f5; }
.book-tab__status { margin-left: 8rpx; font-size: 18rpx; font-weight: 500; }

.book-summary { padding: 24rpx 26rpx; border-left: 6rpx solid #149065; background: #f0f8f4; }
.book-summary__title { color: #173c2c; font-size: 29rpx; font-weight: 800; }
.book-summary__meta { margin-top: 9rpx; color: #386653; font-size: 22rpx; line-height: 1.6; }
.book-summary__note { margin-top: 7rpx; color: #708078; font-size: 20rpx; line-height: 1.6; }
.physics-book-summary { border-left-color: #cf5d2d; background: #fff7f2; }
.physics-book-summary .book-summary__title { color: #66321f; }
.physics-book-summary .book-summary__meta { color: #854d34; }

.unit-list { margin-top: 10rpx; border-top: 1rpx solid #e5e9e7; }
.unit-row {
  display: flex;
  align-items: center;
  min-height: 164rpx;
  padding: 22rpx 6rpx;
  border-bottom: 1rpx solid #e5e9e7;
  background: #ffffff;
}
.unit-row__number {
  display: flex;
  flex: 0 0 64rpx;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  margin-right: 20rpx;
  border-radius: 50%;
  background: #087a4b;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}
.unit-row__body { flex: 1; min-width: 0; }
.unit-row__eyebrow { color: #5d786b; font-size: 20rpx; line-height: 1.5; }
.unit-row__title { margin-top: 4rpx; color: #17233f; font-size: 29rpx; font-weight: 800; line-height: 1.35; }
.unit-row__question { margin-top: 6rpx; color: #5d6677; font-size: 21rpx; line-height: 1.5; }
.unit-row__meta { margin-top: 6rpx; color: #14845a; font-size: 20rpx; }
.unit-row__arrow { flex: 0 0 34rpx; color: #7d8d85; font-size: 42rpx; text-align: right; }
.physics-chapter-row__number { border-radius: 10rpx; background: #c85a2d; }
.physics-chapter-row__eyebrow { color: #815845; }
.physics-chapter-row__meta { color: #b24c23; }

.topic-list { display: grid; gap: 20rpx; }

.subject-topic {
  display: flex;
  min-height: 190rpx;
  padding: 20rpx;
  overflow: hidden;
}

.subject-topic__image {
  flex-shrink: 0;
  width: 190rpx;
  height: 150rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
  background: #edf3f8;
}

.subject-topic__fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #547080;
  font-size: 23rpx;
}

.subject-topic__body { flex: 1; min-width: 0; }
.subject-topic__label { font-size: 21rpx; color: #5d7b70; }
.subject-topic__title { margin-top: 7rpx; font-size: 30rpx; font-weight: 800; line-height: 1.35; color: #17233f; }
.subject-topic__summary { margin-top: 9rpx; font-size: 23rpx; line-height: 1.65; color: #5b667b; }
.subject-topic__meta { margin-top: 10rpx; font-size: 21rpx; color: #7a8498; }
