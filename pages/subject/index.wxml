<view class="page-shell" wx:if="{{subject}}">
  <view class="subject-hero subject-hero--{{subject.id}}">
    <view class="subject-hero__eyebrow">{{subject.gradeText}}</view>
    <view class="subject-hero__title">{{subject.name}}</view>
    <view class="subject-hero__desc">{{subject.description}}</view>
    <view class="subject-hero__stats">
      <block wx:if="{{isEnglish}}">
        <view class="subject-stat"><text class="subject-stat__num">{{subject.unitCount}}</text><text>教材单元</text></view>
        <view class="subject-stat"><text class="subject-stat__num">{{subject.vocabularyCount}}</text><text>逐词讲解</text></view>
        <view class="subject-stat"><text class="subject-stat__num">{{subject.grammarCount}}</text><text>单元语法</text></view>
      </block>
      <block wx:elif="{{isPhysics}}">
        <view class="subject-stat"><text class="subject-stat__num">{{subject.chapterCount}}</text><text>教材章节</text></view>
        <view class="subject-stat"><text class="subject-stat__num">{{subject.knowledgeCount}}</text><text>章节知识点</text></view>
        <view class="subject-stat"><text class="subject-stat__num">{{subject.templateCount}}</text><text>解题方法</text></view>
      </block>
      <block wx:else>
        <view class="subject-stat"><text class="subject-stat__num">{{subject.topicCount}}</text><text>专题</text></view>
        <view class="subject-stat"><text class="subject-stat__num">{{subject.knowledgeCount}}</text><text>知识点</text></view>
        <view class="subject-stat"><text class="subject-stat__num">{{subject.templateCount}}</text><text>方法模板</text></view>
      </block>
    </view>
  </view>

  <view class="subject-search" bindtap="openSearch">搜索{{subject.shortName}}知识与方法</view>

  <block wx:if="{{isEnglish}}">
    <view class="section-title top-gap">
      <view class="section-title__main">按教材单元学习</view>
      <view class="section-title__sub">人教版新版教材</view>
    </view>

    <scroll-view class="book-tabs" scroll-x enable-flex>
      <view class="book-tabs__inner">
        <view wx:for="{{books}}" wx:key="id" class="book-tab {{item.id === selectedBookId ? 'book-tab--active' : ''}} {{item.disabled ? 'book-tab--disabled' : ''}}" data-id="{{item.id}}" bindtap="selectBook">
          <text>{{item.shortLabel}}</text>
          <text wx:if="{{item.disabled}}" class="book-tab__status">待发布</text>
        </view>
      </view>
    </scroll-view>

    <view wx:if="{{selectedBook}}" class="book-summary">
      <view class="book-summary__title">{{selectedBook.label}}</view>
      <view class="book-summary__meta">{{selectedBook.unitCount}} 个单元 · {{selectedBook.vocabularyCount}} 个逐词讲解 · {{selectedBook.grammarCount}} 个语法点</view>
      <view class="book-summary__note">{{selectedBook.sourceNote}}</view>
    </view>

    <view class="unit-list">
      <view wx:for="{{units}}" wx:key="id" class="unit-row" data-id="{{item.id}}" bindtap="openEnglishUnit">
        <view class="unit-row__number">{{item.isStarter ? 'S' + item.number : item.number}}</view>
        <view class="unit-row__body">
          <view class="unit-row__eyebrow">{{item.unitLabel}} · {{item.theme}}</view>
          <view class="unit-row__title">{{item.title}}</view>
          <view class="unit-row__meta">{{item.vocabularyCount}} 个核心词 · {{item.grammarCount}} 个语法点</view>
        </view>
        <view class="unit-row__arrow">›</view>
      </view>
    </view>
  </block>

  <block wx:if="{{isPhysics}}">
    <view class="section-title top-gap">
      <view class="section-title__main">按教材章节学习</view>
      <view class="section-title__sub">人教版 22 章</view>
    </view>

    <scroll-view class="book-tabs book-tabs--physics" scroll-x enable-flex>
      <view class="book-tabs__inner">
        <view wx:for="{{physicsBooks}}" wx:key="id" class="book-tab physics-book-tab {{item.id === selectedPhysicsBookId ? 'physics-book-tab--active' : ''}}" data-id="{{item.id}}" bindtap="selectPhysicsBook">{{item.shortLabel}}</view>
      </view>
    </scroll-view>

    <view wx:if="{{selectedPhysicsBook}}" class="book-summary physics-book-summary">
      <view class="book-summary__title">{{selectedPhysicsBook.label}}</view>
      <view class="book-summary__meta">{{selectedPhysicsBook.chapterCount}} 章 · {{selectedPhysicsBook.knowledgeCount}} 个知识点 · {{selectedPhysicsBook.exampleCount}} 道原创示例</view>
      <view class="book-summary__note">{{selectedPhysicsBook.sourceNote}}</view>
    </view>

    <view class="unit-list physics-chapter-list">
      <view wx:for="{{physicsChapters}}" wx:key="id" class="unit-row physics-chapter-row" data-id="{{item.id}}" bindtap="openPhysicsChapter">
        <view class="unit-row__number physics-chapter-row__number">{{item.number}}</view>
        <view class="unit-row__body">
          <view class="unit-row__eyebrow physics-chapter-row__eyebrow">{{item.chapterLabel}} · {{item.knowledgeCount}} 个知识点</view>
          <view class="unit-row__title">{{item.title}}</view>
          <view class="unit-row__question">{{item.summary}}</view>
          <view class="unit-row__meta physics-chapter-row__meta">{{item.exampleCount}} 道示例 · 1 个章节方法</view>
        </view>
        <view class="unit-row__arrow">›</view>
      </view>
    </view>
  </block>

  <view class="section-title top-gap">
    <view class="section-title__main">{{isEnglish ? '能力专题' : (isPhysics ? '综合复习专题' : '专题学习')}}</view>
    <view class="section-title__sub">{{topics.length}} 个专题</view>
  </view>

  <view class="topic-list">
    <view wx:for="{{topics}}" wx:key="id" wx:for-item="topic" class="subject-topic card" data-id="{{topic.id}}" bindtap="openTopic">
      <image wx:if="{{topic.coverImage && !topic.imageLoadFailed}}" class="subject-topic__image" src="{{topic.coverImage}}" mode="aspectFill" data-index="{{index}}" binderror="onImageError"></image>
      <view wx:else class="subject-topic__image subject-topic__fallback">{{topic.label}}</view>
      <view class="subject-topic__body">
        <view class="subject-topic__label">{{topic.label}} · {{topic.gradeText}}</view>
        <view class="subject-topic__title">{{topic.title}}</view>
        <view class="subject-topic__summary">{{topic.summary}}</view>
        <view class="subject-topic__meta">{{topic.knowledgeCount}} 个知识点 · {{topic.exampleCount}} 道示例</view>
      </view>
    </view>
  </view>
</view>
