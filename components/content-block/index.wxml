<view class="content-block">
  <view class="content-block__head">
    <view class="content-block__title">{{section.title}}</view>
    <view wx:if="{{section.type === 'formula' || section.type === 'example' || section.type === 'experiment'}}" class="content-block__copy" bindtap="copySection">复制</view>
  </view>

  <view wx:if="{{section.type === 'text'}}" class="content-block__text">{{section.content}}</view>

  <view wx:if="{{section.type === 'formula'}}" class="formula-box">
    <view class="formula-box__formula">{{section.formula}}</view>
    <view class="formula-box__desc">{{section.description}}</view>
  </view>

  <view wx:if="{{section.type === 'tip'}}" class="tip-box">{{section.content}}</view>

  <view wx:if="{{section.type === 'steps'}}" class="steps-box">
    <view wx:for="{{section.steps}}" wx:key="index" class="steps-box__item">
      <view class="steps-box__index">{{index + 1}}</view>
      <view class="steps-box__text">{{item}}</view>
    </view>
  </view>

  <view wx:if="{{section.type === 'list'}}" class="list-box">
    <view wx:for="{{section.items}}" wx:key="index" class="list-box__item">
      <view class="list-box__dot"></view>
      <view class="list-box__text">{{item}}</view>
    </view>
  </view>

  <view wx:if="{{section.type === 'table'}}" class="table-box">
    <view class="table-box__row table-box__row--head">
      <view wx:for="{{section.headers}}" wx:key="index" wx:for-item="header" class="table-box__cell table-box__cell--head">{{header}}</view>
    </view>
    <view wx:for="{{section.rows}}" wx:key="index" wx:for-item="row" class="table-box__row">
      <view wx:for="{{row}}" wx:for-item="cell" wx:for-index="cellIndex" wx:key="cellIndex" class="table-box__cell">{{cell}}</view>
    </view>
  </view>

  <view wx:if="{{section.type === 'example'}}" class="example-box">
    <view class="example-box__sentence">{{section.sentence}}</view>
    <view class="example-box__translation">{{section.translation}}</view>
    <view class="example-box__row"><text class="example-box__label">重点结构</text><text>{{section.focus}}</text></view>
    <view class="example-box__row"><text class="example-box__label">使用提醒</text><text>{{section.note}}</text></view>
  </view>

  <view wx:if="{{section.type === 'experiment'}}" class="experiment-box">
    <view class="experiment-box__row"><text class="experiment-box__label">目的</text><text>{{section.goal}}</text></view>
    <view class="experiment-box__row"><text class="experiment-box__label">器材</text><text>{{section.apparatusText}}</text></view>
    <view class="experiment-box__steps">
      <view wx:for="{{section.steps}}" wx:key="index" class="experiment-step"><text class="experiment-step__index">{{index + 1}}</text><text>{{item}}</text></view>
    </view>
    <view class="experiment-box__row"><text class="experiment-box__label">现象</text><text>{{section.phenomenon}}</text></view>
    <view class="experiment-box__row"><text class="experiment-box__label">结论</text><text>{{section.conclusion}}</text></view>
    <view class="experiment-box__row"><text class="experiment-box__label">误差</text><text>{{section.errorsText}}</text></view>
    <view class="experiment-box__row experiment-box__row--safe"><text class="experiment-box__label">安全</text><text>{{section.safety}}</text></view>
  </view>
</view>
