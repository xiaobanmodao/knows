.content-block {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 12rpx 36rpx rgba(45, 79, 168, 0.08);
}

.content-block__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.content-block__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1c2640;
}

.content-block__copy {
  flex-shrink: 0;
  color: #1d5de1;
  font-size: 22rpx;
  font-weight: 700;
}

.content-block__text {
  line-height: 1.9;
  color: #3b465d;
  font-size: 26rpx;
}

.formula-box {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #f2f6ff;
}

.formula-box__formula {
  font-size: 28rpx;
  font-weight: 700;
  color: #174ec7;
  line-height: 1.6;
}

.formula-box__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #556178;
  line-height: 1.8;
}

.tip-box {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fff7e8;
  color: #8d5a00;
  font-size: 25rpx;
  line-height: 1.8;
}

.steps-box__item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.steps-box__item:last-child {
  margin-bottom: 0;
}

.steps-box__index {
  width: 44rpx;
  height: 44rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 44rpx;
  background: #1f63ff;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.steps-box__text {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.8;
  color: #34405a;
}

.list-box__item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.list-box__item:last-child {
  margin-bottom: 0;
}

.list-box__dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 12rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: #1d63ff;
  flex-shrink: 0;
}

.list-box__text {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.8;
  color: #33415d;
}

.table-box {
  border-radius: 24rpx;
  overflow: hidden;
  border: 2rpx solid #e6ecfa;
}

.table-box__row {
  display: flex;
}

.table-box__row--head {
  background: #eef3ff;
}

.table-box__cell {
  flex: 1;
  padding: 18rpx 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #33415d;
  border-right: 2rpx solid #e6ecfa;
  border-bottom: 2rpx solid #e6ecfa;
}

.table-box__cell:last-child {
  border-right: 0;
}

.table-box__cell--head {
  font-weight: 700;
  color: #18356c;
}

.example-box {
  padding: 22rpx;
  border-left: 6rpx solid #168454;
  border-radius: 16rpx;
  background: #f0faf5;
}

.example-box__sentence { font-size: 28rpx; line-height: 1.7; font-weight: 700; color: #183d2e; }
.example-box__translation { margin-top: 8rpx; font-size: 24rpx; line-height: 1.7; color: #526b61; }
.example-box__row, .experiment-box__row { display: flex; gap: 16rpx; margin-top: 14rpx; font-size: 24rpx; line-height: 1.75; color: #40536a; }
.example-box__label, .experiment-box__label { flex-shrink: 0; color: #15704a; font-weight: 700; }

.experiment-box {
  padding: 22rpx;
  border-left: 6rpx solid #d16a25;
  border-radius: 16rpx;
  background: #fff8f0;
}

.experiment-box__steps { margin-top: 16rpx; padding: 16rpx; border-radius: 12rpx; background: #ffffff; }
.experiment-step { display: flex; gap: 12rpx; margin-top: 10rpx; font-size: 24rpx; line-height: 1.7; color: #425066; }
.experiment-step:first-child { margin-top: 0; }
.experiment-step__index { flex-shrink: 0; color: #bd5a1b; font-weight: 800; }
.experiment-box__row--safe { padding-top: 12rpx; border-top: 1rpx solid #f1d8c4; color: #8b4d22; }
