.subject-card {
  padding: 28rpx;
  border-radius: 28rpx;
  color: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(32, 58, 132, 0.12);
}

.subject-card__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.subject-card__title {
  font-size: 32rpx;
  font-weight: 700;
}

.subject-card__subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.88;
}

.subject-card__badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 20rpx;
}

.subject-card__desc {
  font-size: 24rpx;
  line-height: 1.7;
  opacity: 0.94;
}

.math {
  background: linear-gradient(135deg, #165dff 0%, #5b8cff 100%);
}

.english {
  background: linear-gradient(135deg, #0f9d58 0%, #48c28d 100%);
}

.physics {
  background: linear-gradient(135deg, #ef6b2f 0%, #f5a63a 100%);
}

.subject-card--coming {
  opacity: 0.86;
}
